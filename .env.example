# Turso (SQLite)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Auth.js
AUTH_SECRET=  # openssl rand -base64 32
AUTH_RESEND_KEY=  # Resend API key for magic link emails
ALLOWED_EMAILS=your@email.com  # comma-separated allowlist

# Deepgram (STT)
DEEPGRAM_API_KEY=

# OpenAI (TTS)
OPENAI_API_KEY=

# Anthropic (LLM)
ANTHROPIC_API_KEY=

# App
NEXTAUTH_URL=http://localhost:3000
